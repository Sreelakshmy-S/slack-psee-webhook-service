{
  "name": "slack-psee-webhook-service",
  "version": "1.0.0",
  "description": "Webhook service for Slack PSEE auto-tagging workflow",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "deploy:lambda": "serverless deploy",
    "logs:lambda": "serverless logs -f webhook -t",
    "offline": "serverless offline"
  },
  "keywords": [
    "slack",
    "webhook",
    "psee",
    "automation"
  ],
  "author": "IBM Support Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "@slack/web-api": "^6.10.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "eslint": "^8.54.0",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}